@model EventEase.Models.ViewModels.EditPreBookingViewModel

@{
    ViewData["Title"] = "Edit Pre-Booking";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-pencil"></i> Edit Pre-Booking
    </h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <form asp-action="Edit">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                        <input type="hidden" asp-for="PreBookingId" />

                        <h6 class="text-primary">Customer Information</h6>
                        <hr />
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CustomerName" class="form-label"></label>
                                    <input asp-for="CustomerName" class="form-control" />
                                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CustomerPhone" class="form-label"></label>
                                    <input asp-for="CustomerPhone" class="form-control" />
                                    <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CustomerEmail" class="form-label"></label>
                            <input asp-for="CustomerEmail" class="form-control" type="email" />
                            <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                        </div>

                        <h6 class="text-primary mt-4">Event Information</h6>
                        <hr />
                        <div class="mb-3">
                            <label asp-for="EventName" class="form-label"></label>
                            <input asp-for="EventName" class="form-control" />
                            <span asp-validation-for="EventName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EventDescription" class="form-label"></label>
                            <textarea asp-for="EventDescription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="EventDescription" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExpectedAttendees" class="form-label"></label>
                            <input asp-for="ExpectedAttendees" class="form-control" type="number" />
                            <span asp-validation-for="ExpectedAttendees" class="text-danger"></span>
                        </div>

                        <h6 class="text-primary mt-4">Venue Preferences</h6>
                        <hr />
                        <div class="mb-3">
                            <label asp-for="PreferredVenueId" class="form-label">Preferred Venue</label>
                            <select asp-for="PreferredVenueId" class="form-select" asp-items="ViewBag.Venues">
                                <option value="">-- No specific preference --</option>
                            </select>
                            <span asp-validation-for="PreferredVenueId" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PreferredStartDate" class="form-label">Preferred Start Date</label>
                                <input asp-for="PreferredStartDate" class="form-control" type="date" id="startDate" />
                                <span asp-validation-for="PreferredStartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PreferredEndDate" class="form-label">Preferred End Date</label>
                                <input asp-for="PreferredEndDate" class="form-control" type="date" id="endDate" />
                                <span asp-validation-for="PreferredEndDate" class="text-danger"></span>
                            </div>
                        </div>

                        <h6 class="text-primary mt-4">Status & Notes</h6>
                        <hr />
                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Waiting">Waiting</option>
                                <option value="Notified">Notified</option>
                                <option value="Expired">Expired</option>
                                <option value="Cancelled">Cancelled</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Save Changes
                            </button>
                            <a asp-action="Details" asp-route-id="@Model.PreBookingId" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Details
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card bg-light">
                <div class="card-body">
                    <h5 class="card-title"><i class="bi bi-info-circle"></i> Edit Information</h5>
                    <ul class="small">
                        <li>You can update customer details anytime</li>
                        <li>Event information can be modified</li>
                        <li>Change venue preferences as needed</li>
                        <li>Update status to track progress</li>
                        <li>Add notes for internal use</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            // Set min date for start date to today
            var today = new Date().toISOString().split('T')[0];
            $('#startDate').attr('min', today);

            // When start date changes, update end date min
            $('#startDate').on('change', function() {
                var startDate = $(this).val();
                $('#endDate').attr('min', startDate);

                // If end date is less than start date, clear it
                var endDate = $('#endDate').val();
                if (endDate && endDate < startDate) {
                    $('#endDate').val('');
                }
            });

            // Trigger change on page load if start date has value
            if ($('#startDate').val()) {
                $('#startDate').trigger('change');
            }
        });
    </script>
}