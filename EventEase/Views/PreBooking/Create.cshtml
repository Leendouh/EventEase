@model EventEase.Models.ViewModels.CreatePreBookingViewModel

@{
    ViewData["Title"] = "Create Pre-Booking";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-plus-circle"></i> Create Pre-Booking
    </h1>

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        Use this form when a venue is not available. The customer will be added to a waiting list
        and notified when their preferred venue becomes available.
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <form asp-action="Create">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <h6 class="text-primary">Customer Information</h6>
                        <hr />
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CustomerName" class="form-label"></label>
                                    <input asp-for="CustomerName" class="form-control" />
                                    <span asp-validation-for="CustomerName" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="CustomerPhone" class="form-label"></label>
                                    <input asp-for="CustomerPhone" class="form-control" />
                                    <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="CustomerEmail" class="form-label"></label>
                            <input asp-for="CustomerEmail" class="form-control" type="email" />
                            <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                        </div>

                        <h6 class="text-primary mt-4">Event Information</h6>
                        <hr />
                        <div class="mb-3">
                            <label asp-for="EventName" class="form-label"></label>
                            <input asp-for="EventName" class="form-control" />
                            <span asp-validation-for="EventName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EventDescription" class="form-label"></label>
                            <textarea asp-for="EventDescription" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="EventDescription" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ExpectedAttendees" class="form-label"></label>
                            <input asp-for="ExpectedAttendees" class="form-control" type="number" />
                            <span asp-validation-for="ExpectedAttendees" class="text-danger"></span>
                        </div>

                        <h6 class="text-primary mt-4">Venue Preferences</h6>
                        <hr />
                        <div class="mb-3">
                            <label asp-for="PreferredVenueId" class="form-label">Preferred Venue</label>
                            <select asp-for="PreferredVenueId" class="form-select" asp-items="ViewBag.Venues">
                                <option value="">-- No specific preference --</option>
                            </select>
                            <span asp-validation-for="PreferredVenueId" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="PreferredStartDate" class="form-label"></label>
                                <input asp-for="PreferredStartDate" class="form-control" type="date" 
                                       id="preferredStartDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="PreferredStartDate" class="text-danger"></span>
                                <div class="invalid-feedback" id="startDateError" style="display: none;"></div>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="PreferredEndDate" class="form-label"></label>
                                <input asp-for="PreferredEndDate" class="form-control" type="date" 
                                       id="preferredEndDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" />
                                <span asp-validation-for="PreferredEndDate" class="text-danger"></span>
                                <div class="invalid-feedback" id="endDateError" style="display: none;"></div>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Notes" class="form-label"></label>
                            <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                            <span asp-validation-for="Notes" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Create Pre-Booking
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Back to List
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        $(document).ready(function() {
            var today = new Date().toISOString().split('T')[0];
            
            // Real-time validation for start date
            $('#preferredStartDate').on('change blur', function() {
                var startDate = $(this).val();
                var endDate = $('#preferredEndDate').val();
                var $startDateError = $('#startDateError');
                var $endDate = $('#preferredEndDate');
                
                // Clear previous errors
                $(this).removeClass('is-invalid');
                $startDateError.hide();
                
                if (startDate) {
                    // Check if start date is in the past
                    if (startDate < today) {
                        $(this).addClass('is-invalid');
                        $startDateError.text('Start date cannot be in the past').show();
                        return;
                    }
                    
                    // Update end date minimum
                    $endDate.attr('min', startDate);
                    
                    // Check if end date is before start date
                    if (endDate && endDate < startDate) {
                        $endDate.addClass('is-invalid');
                        $('#endDateError').text('End date must be after or equal to start date').show();
                    } else {
                        $endDate.removeClass('is-invalid');
                        $('#endDateError').hide();
                    }
                }
            });
            
            // Real-time validation for end date
            $('#preferredEndDate').on('change blur', function() {
                var endDate = $(this).val();
                var startDate = $('#preferredStartDate').val();
                var $endDateError = $('#endDateError');
                
                // Clear previous errors
                $(this).removeClass('is-invalid');
                $endDateError.hide();
                
                if (endDate) {
                    // Check if end date is in the past
                    if (endDate < today) {
                        $(this).addClass('is-invalid');
                        $endDateError.text('End date cannot be in the past').show();
                        return;
                    }
                    
                    // Check if end date is before start date
                    if (startDate && endDate < startDate) {
                        $(this).addClass('is-invalid');
                        $endDateError.text('End date must be after or equal to start date').show();
                    }
                }
            });
            
            // Form submission validation
            $('form').on('submit', function(e) {
                var startDate = $('#preferredStartDate').val();
                var endDate = $('#preferredEndDate').val();
                var hasError = false;
                
                // Validate start date
                if (startDate && startDate < today) {
                    $('#preferredStartDate').addClass('is-invalid');
                    $('#startDateError').text('Start date cannot be in the past').show();
                    hasError = true;
                }
                
                // Validate end date
                if (endDate) {
                    if (endDate < today) {
                        $('#preferredEndDate').addClass('is-invalid');
                        $('#endDateError').text('End date cannot be in the past').show();
                        hasError = true;
                    } else if (startDate && endDate < startDate) {
                        $('#preferredEndDate').addClass('is-invalid');
                        $('#endDateError').text('End date must be after or equal to start date').show();
                        hasError = true;
                    }
                }
                
                if (hasError) {
                    e.preventDefault();
                    return false;
                }
            });
        });
    </script>
}