@model EventEase.Models.ApplicationUser

@{
    ViewData["Title"] = "Reset Password";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-key"></i> Reset Password
    </h1>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-header bg-warning">
                    <h5 class="mb-0">Reset Password for @Model.FullName</h5>
                </div>
                <div class="card-body">
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i>
                        This will reset the admin's password and force them to change it on next login.
                    </div>

                    <dl class="row">
                        <dt class="col-sm-3">Admin ID:</dt>
                        <dd class="col-sm-9">@Model.FormattedAdminId</dd>

                        <dt class="col-sm-3">Username:</dt>
                        <dd class="col-sm-9">@Model.UserName</dd>

                        <dt class="col-sm-3">Full Name:</dt>
                        <dd class="col-sm-9">@Model.FullName</dd>

                        <dt class="col-sm-3">Email:</dt>
                        <dd class="col-sm-9">@Model.Email</dd>

                        <dt class="col-sm-3">Role:</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-@(Model.Role == "SuperAdmin" ? "danger" : "info")">
                                @Model.Role
                            </span>
                        </dd>
                    </dl>

                    <form asp-action="ResetPassword" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.AdminId" />

                        <div class="mb-3">
                            <label for="newPassword" class="form-label">New Password</label>
                            <input type="password" class="form-control" id="newPassword" name="newPassword"
                                   required minlength="6" placeholder="Enter new password" />
                            <small class="text-muted">Minimum 6 characters</small>
                        </div>

                        <div class="mb-3">
                            <label for="confirmPassword" class="form-label">Confirm New Password</label>
                            <input type="password" class="form-control" id="confirmPassword"
                                   required minlength="6" placeholder="Confirm new password" />
                        </div>

                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-key"></i> Reset Password
                        </button>
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left"></i> Back to List
                        </a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelector('form').addEventListener('submit', function(e) {
            var newPass = document.getElementById('newPassword').value;
            var confirmPass = document.getElementById('confirmPassword').value;

            if (newPass !== confirmPass) {
                e.preventDefault();
                alert('Passwords do not match!');
            }

            if (newPass.length < 6) {
                e.preventDefault();
                alert('Password must be at least 6 characters long!');
            }
        });
    </script>
}