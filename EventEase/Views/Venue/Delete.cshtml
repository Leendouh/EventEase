@model EventEase.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4 text-danger">
        <i class="bi bi-exclamation-triangle"></i> Delete Venue
    </h1>

    <div class="alert alert-warning">
        <i class="bi bi-exclamation-triangle"></i> Are you sure you want to delete this venue? This action cannot be undone.
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-3">Venue ID</dt>
                        <dd class="col-sm-9">@Model.FormattedVenueId</dd>

                        <dt class="col-sm-3">Name</dt>
                        <dd class="col-sm-9">@Model.VenueName</dd>

                        <dt class="col-sm-3">Location</dt>
                        <dd class="col-sm-9">@Model.Location</dd>

                        <dt class="col-sm-3">Capacity</dt>
                        <dd class="col-sm-9">@Model.Capacity</dd>

                        <dt class="col-sm-3">Status</dt>
                        <dd class="col-sm-9">
                            <span class="badge bg-@(Model.IsAvailable ? "success" : "secondary")">
                                @(Model.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </dd>
                    </dl>

                    @if (Model.Bookings != null && Model.Bookings.Any())
                    {
                        <div class="alert alert-danger">
                            <i class="bi bi-exclamation-triangle"></i>
                            This venue has active bookings and cannot be deleted.
                        </div>
                        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                    }
                    else
                    {
                        <form asp-action="Delete" method="post">
                            <input type="hidden" asp-for="VenueId" />
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash"></i> Delete Venue
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Cancel
                            </a>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>