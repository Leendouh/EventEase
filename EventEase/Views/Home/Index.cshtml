@model IEnumerable<EventEase.Models.Booking>

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-speedometer2"></i> Dashboard
    </h1>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card text-white bg-primary">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Venues</h6>
                            <h2 class="mb-0">@ViewBag.TotalVenues</h2>
                        </div>
                        <i class="bi bi-building fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-success">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Events</h6>
                            <h2 class="mb-0">@ViewBag.TotalEvents</h2>
                        </div>
                        <i class="bi bi-calendar-event fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-info">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Total Bookings</h6>
                            <h2 class="mb-0">@ViewBag.TotalBookings</h2>
                        </div>
                        <i class="bi bi-journal-bookmark-fill fs-1"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card text-white bg-warning">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title">Pending Bookings</h6>
                            <h2 class="mb-0">@ViewBag.PendingBookings</h2>
                        </div>
                        <i class="bi bi-hourglass-split fs-1"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-lightning"></i> Quick Actions</h5>
                </div>
                <div class="card-body">
                    <a asp-controller="Venue" asp-action="Create" class="btn btn-primary me-2">
                        <i class="bi bi-plus-circle"></i> Add Venue
                    </a>
                    <a asp-controller="Event" asp-action="Create" class="btn btn-success me-2">
                        <i class="bi bi-plus-circle"></i> Add Event
                    </a>
                    <a asp-controller="Booking" asp-action="Create" class="btn btn-info text-white me-2">
                        <i class="bi bi-plus-circle"></i> New Booking
                    </a>
                    <!-- FIXED: Changed from "Search" to "Index" -->
                    <a asp-controller="Booking" asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-search"></i> Search Bookings
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Popular Venues Section -->
    @if (ViewBag.PopularVenues != null && ((IEnumerable<EventEase.Models.Venue>)ViewBag.PopularVenues).Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-stars"></i> Popular Venues</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var venue in ViewBag.PopularVenues)
                            {
                                <div class="col-md-4 mb-3">
                                    <div class="card h-100">
                                        <img src="@venue.ImageUrl" class="card-img-top" alt="@venue.VenueName"
                                             style="height: 150px; object-fit: cover;"
                                             onerror="this.src='https://via.placeholder.com/300x150?text=No+Image'">
                                        <div class="card-body">
                                            <h5 class="card-title">@venue.VenueName</h5>
                                            <p class="card-text small">
                                                <i class="bi bi-geo-alt"></i> @venue.Location<br>
                                                <i class="bi bi-people"></i> Capacity: @venue.Capacity<br>
                                                <i class="bi bi-tag"></i> @venue.FormattedVenueId
                                            </p>
                                            <a asp-controller="Venue" asp-action="Details" asp-route-id="@venue.VenueId"
                                               class="btn btn-sm btn-outline-primary">View Details</a>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Recent Bookings Section -->
    @if (ViewBag.RecentBookings != null && ((IEnumerable<EventEase.Models.Booking>)ViewBag.RecentBookings).Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-white">
                        <h5 class="mb-0"><i class="bi bi-clock-history"></i> Recent Bookings</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm">
                                <thead>
                                    <tr>
                                        <th>Booking #</th>
                                        <th>Customer</th>
                                        <th>Event</th>
                                        <th>Venue</th>
                                        <th>Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in ViewBag.RecentBookings)
                                    {
                                        <tr>
                                            <td>@item.BookingNumber</td>
                                            <td>@item.CustomerName @item.CustomerSurname</td>
                                            <td>@(item.Event?.EventName ?? "N/A")</td>
                                            <td>@(item.Venue?.VenueName ?? "N/A")</td>
                                            <td>@item.StartDate.ToString("dd MMM")</td>
                                            <td>
                                                <span class="badge bg-@(item.Status == "Confirmed" ? "success" :
                                                                                                          item.Status == "Pending" ? "warning" :
                                                                                                          item.Status == "Cancelled" ? "danger" : "secondary")">
                                            @item.Status
                                        </span>
                                    </td>
                                </tr>
                            }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Upcoming Bookings -->
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-white">
                    <h5 class="mb-0"><i class="bi bi-calendar-week"></i> Upcoming Bookings</h5>
                </div>
                <div class="card-body">
                    @if (Model != null && Model.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Booking #</th>
                                        <th>Customer</th>
                                        <th>Event</th>
                                        <th>Venue</th>
                                        <th>Start Date</th>
                                        <th>Status</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model)
                                    {
                                        <tr>
                                            <td><strong>@item.BookingNumber</strong></td>
                                            <td>@item.CustomerName @item.CustomerSurname</td>
                                            <td>@(item.Event?.EventName ?? "N/A")</td>
                                            <td>@(item.Venue?.VenueName ?? "N/A")</td>
                                            <td>@item.StartDate.ToString("dd MMM yyyy HH:mm")</td>
                                            <td>
                                                <span class="badge bg-@(item.Status == "Confirmed" ? "success" :
                                                                                                          item.Status == "Pending" ? "warning" :
                                                                                                          item.Status == "Cancelled" ? "danger" : "secondary")">
                                            @item.Status
                                        </span>
                                    </td>
                                    <td>
                                        <a asp-controller="Booking" asp-action="Details" asp-route-id="@item.BookingId"
                                           class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-0">No upcoming bookings found.</p>
                    }
                </div>
            </div>
        </div>
    </div>
</div>