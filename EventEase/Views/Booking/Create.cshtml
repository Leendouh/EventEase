@model EventEase.Models.Booking

@{
    ViewData["Title"] = "Create Booking";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-plus-circle"></i> Create New Booking
    </h1>

    @if (ViewBag.Events == null || ((SelectList)ViewBag.Events).Count() == 0 ||
        ViewBag.Venues == null || ((SelectList)ViewBag.Venues).Count() == 0)
    {
        <div class="alert alert-warning">
            <i class="bi bi-exclamation-triangle"></i>
            <strong>Unable to load booking form.</strong>
            Please ensure you have at least one event and one available venue in the system.
            <hr />
            <a asp-controller="Event" asp-action="Create" class="btn btn-sm btn-success">Create Event</a>
            <a asp-controller="Venue" asp-action="Create" class="btn btn-sm btn-primary">Create Venue</a>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-header bg-white">
                        <h5 class="mb-0">Booking Details</h5>
                    </div>
                    <div class="card-body">
                        <form asp-action="Create" id="bookingForm">
                            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                            <h6 class="text-primary">Event Information</h6>
                            <hr />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="EventId" class="form-label">Select Event</label>
                                        <select asp-for="EventId" class="form-select" asp-items="ViewBag.Events">
                                            <option value="">-- Select Event --</option>
                                        </select>
                                        <span asp-validation-for="EventId" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="VenueId" class="form-label">Select Venue</label>
                                        <select asp-for="VenueId" class="form-select" asp-items="ViewBag.Venues" id="venueSelect">
                                            <option value="">-- Select Venue --</option>
                                        </select>
                                        <span asp-validation-for="VenueId" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Real-time Venue Availability Check -->
                            <div id="venueAvailabilityAlert" class="alert" style="display: none;">
                                <div class="d-flex align-items-center">
                                    <div class="spinner-border spinner-border-sm me-2" id="availabilitySpinner" role="status" style="display: none;">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <div id="availabilityMessage"></div>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="StartDate" class="form-label">Start Date & Time</label>
                                        <input asp-for="StartDate" class="form-control" type="datetime-local"
                                               id="startDate" min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                        <span asp-validation-for="StartDate" class="text-danger"></span>
                                        <div class="invalid-feedback" id="startDateError" style="display: none;"></div>
                                        <small class="text-muted">Must be today or later</small>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="EndDate" class="form-label">End Date & Time</label>
                                        <input asp-for="EndDate" class="form-control" type="datetime-local"
                                               id="endDate" />
                                        <span asp-validation-for="EndDate" class="text-danger"></span>
                                        <div class="invalid-feedback" id="endDateError" style="display: none;"></div>
                                        <small class="text-muted">Must be after start date</small>
                                    </div>
                                </div>
                            </div>

                            <h6 class="text-primary mt-4">Customer Information</h6>
                            <hr />
                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CustomerName" class="form-label"></label>
                                        <input asp-for="CustomerName" class="form-control" />
                                        <span asp-validation-for="CustomerName" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CustomerSurname" class="form-label"></label>
                                        <input asp-for="CustomerSurname" class="form-control" />
                                        <span asp-validation-for="CustomerSurname" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CustomerPhone" class="form-label"></label>
                                        <input asp-for="CustomerPhone" class="form-control" />
                                        <span asp-validation-for="CustomerPhone" class="text-danger"></span>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="CustomerEmail" class="form-label"></label>
                                        <input asp-for="CustomerEmail" class="form-control" type="email" />
                                        <span asp-validation-for="CustomerEmail" class="text-danger"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="CustomerIDNumber" class="form-label">ID/Passport Number (Optional)</label>
                                <input asp-for="CustomerIDNumber" class="form-control" />
                                <span asp-validation-for="CustomerIDNumber" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="CustomerAddress" class="form-label">Address (Optional)</label>
                                <textarea asp-for="CustomerAddress" class="form-control" rows="2"></textarea>
                                <span asp-validation-for="CustomerAddress" class="text-danger"></span>
                            </div>

                            <div class="form-group mb-3">
                                <label asp-for="Notes" class="form-label">Additional Notes</label>
                                <textarea asp-for="Notes" class="form-control" rows="2"></textarea>
                                <span asp-validation-for="Notes" class="text-danger"></span>
                            </div>

                            <div class="form-group">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i> Create Booking
                                </button>
                                <a asp-action="Index" class="btn btn-secondary">
                                    <i class="bi bi-arrow-left"></i> Back to List
                                </a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card bg-light">
                    <div class="card-body">
                        <h5 class="card-title"><i class="bi bi-info-circle"></i> Important Notes</h5>
                        <ul class="small">
                            <li>The system will automatically check venue availability</li>
                            <li>Double bookings are prevented</li>
                            <li>Customer phone number is required</li>
                            <li>Start date must be today or later</li>
                            <li>End date must be after start date</li>
                            <li>Booking number is auto-generated</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function() {
            // Get today's date and time in the format required for datetime-local
            var today = new Date();
            var year = today.getFullYear();
            var month = String(today.getMonth() + 1).padStart(2, '0');
            var day = String(today.getDate()).padStart(2, '0');
            var hours = String(today.getHours()).padStart(2, '0');
            var minutes = String(today.getMinutes()).padStart(2, '0');

            var currentDateTime = year + '-' + month + '-' + day + 'T' + hours + ':' + minutes;

            // Set min attribute for start date
            $('#startDate').attr('min', currentDateTime);

            // Real-time validation for start date
            $('#startDate').on('change blur', function() {
                var startDate = $(this).val();
                var endDate = $('#endDate').val();
                var $startDateError = $('#startDateError');
                var $endDate = $('#endDate');
                
                // Clear previous errors
                $(this).removeClass('is-invalid');
                $startDateError.hide();
                
                if (startDate) {
                    // Check if start date is in the past
                    var startDateObj = new Date(startDate);
                    if (startDateObj < today) {
                        $(this).addClass('is-invalid');
                        $startDateError.text('Start date cannot be in the past').show();
                        return;
                    }
                    
                    // Update end date minimum
                    $endDate.attr('min', startDate);
                    
                    // Check if end date is before start date
                    if (endDate && new Date(endDate) <= startDateObj) {
                        $endDate.addClass('is-invalid');
                        $('#endDateError').text('End date must be after start date').show();
                    } else {
                        $endDate.removeClass('is-invalid');
                        $('#endDateError').hide();
                    }
                }
            });
            
            // Real-time validation for end date
            $('#endDate').on('change blur', function() {
                var endDate = $(this).val();
                var startDate = $('#startDate').val();
                var $endDateError = $('#endDateError');
                
                // Clear previous errors
                $(this).removeClass('is-invalid');
                $endDateError.hide();
                
                if (endDate && startDate) {
                    var endDateObj = new Date(endDate);
                    var startDateObj = new Date(startDate);
                    
                    // Check if end date is before or equal to start date
                    if (endDateObj <= startDateObj) {
                        $(this).addClass('is-invalid');
                        $endDateError.text('End date must be after start date').show();
                    }
                }
            });

            // Validate form before submission
            $('#bookingForm').on('submit', function(e) {
                var startDate = $('#startDate').val();
                var endDate = $('#endDate').val();
                var hasError = false;
                
                // Validate start date
                if (startDate && new Date(startDate) < today) {
                    $('#startDate').addClass('is-invalid');
                    $('#startDateError').text('Start date cannot be in the past').show();
                    hasError = true;
                }
                
                // Validate end date
                if (endDate && startDate) {
                    if (new Date(endDate) <= new Date(startDate)) {
                        $('#endDate').addClass('is-invalid');
                        $('#endDateError').text('End date must be after start date').show();
                        hasError = true;
                    }
                }
                
                if (hasError) {
                    e.preventDefault();
                    return false;
                }
                
                return true;
            });

            // Real-time venue availability checking
            var availabilityCheckTimeout;
            
            function checkVenueAvailability() {
                var venueId = $('#venueSelect').val();
                var startDate = $('#startDate').val();
                var endDate = $('#endDate').val();
                
                // Clear previous timeout
                clearTimeout(availabilityCheckTimeout);
                
                // Only check if all fields are filled
                if (!venueId || !startDate || !endDate) {
                    $('#venueAvailabilityAlert').hide();
                    return;
                }
                
                // Validate dates before checking availability
                var startDateObj = new Date(startDate);
                var endDateObj = new Date(endDate);
                var today = new Date();
                
                if (startDateObj < today || endDateObj <= startDateObj) {
                    return;
                }
                
                // Show loading state
                $('#venueAvailabilityAlert').removeClass('alert-success alert-danger alert-warning').addClass('alert-info');
                $('#availabilitySpinner').show();
                $('#availabilityMessage').text('Checking venue availability...');
                $('#venueAvailabilityAlert').show();
                
                // Debounce the API call
                availabilityCheckTimeout = setTimeout(function() {
                    $.ajax({
                        url: '@Url.Action("CheckVenueAvailability", "Booking")',
                        type: 'GET',
                        data: {
                            venueId: venueId,
                            startDate: startDate,
                            endDate: endDate
                        },
                        success: function(response) {
                            $('#availabilitySpinner').hide();
                            
                            if (response.available) {
                                $('#venueAvailabilityAlert').removeClass('alert-info alert-danger alert-warning').addClass('alert-success');
                                $('#availabilityMessage').html('<i class="bi bi-check-circle-fill"></i> ' + response.message);
                                
                                // Enable submit button if venue is available
                                $('button[type="submit"]').prop('disabled', false);
                            } else {
                                $('#venueAvailabilityAlert').removeClass('alert-info alert-success alert-warning').addClass('alert-danger');
                                var message = '<i class="bi bi-exclamation-triangle-fill"></i> <strong>Venue Not Available!</strong><br>' + response.message;
                                
                                if (response.conflictingBooking) {
                                    message += '<br><small class="text-muted">Conflicting Booking: ' + response.conflictingBooking.bookingNumber + '</small>';
                                }
                                
                                $('#availabilityMessage').html(message);
                                
                                // Disable submit button if venue is not available
                                $('button[type="submit"]').prop('disabled', true);
                            }
                        },
                        error: function() {
                            $('#availabilitySpinner').hide();
                            $('#venueAvailabilityAlert').removeClass('alert-info alert-success alert-danger').addClass('alert-warning');
                            $('#availabilityMessage').html('<i class="bi bi-exclamation-triangle-fill"></i> Unable to check venue availability. Please try again.');
                            $('button[type="submit"]').prop('disabled', false); // Allow submission on error
                        }
                    });
                }, 500); // 500ms debounce
            }
            
            // Bind change events to trigger availability check
            $('#venueSelect, #startDate, #endDate').on('change', function() {
                checkVenueAvailability();
            });
            
            // Also check on blur for better UX
            $('#venueSelect, #startDate, #endDate').on('blur', function() {
                checkVenueAvailability();
            });
        });
    </script>
}