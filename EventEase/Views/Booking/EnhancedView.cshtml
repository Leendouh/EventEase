@model Tuple<List<EventEase.Models.ViewModels.BookingDetailsViewModel>, EventEase.Models.ViewModels.PaginationViewModel>

@{
    ViewData["Title"] = "Enhanced Booking Management";
}

<div class="container mt-4">
    <h1 class="display-6 mb-4">
        <i class="bi bi-calendar-check"></i> Enhanced Booking Management
    </h1>

    <!-- Search and Filter Section -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-search"></i> Search & Filter Bookings</h5>
        </div>
        <div class="card-body">
            <form asp-action="EnhancedView" method="get" id="searchForm">
                <div class="row g-3">
                    <!-- General Search -->
                    <div class="col-md-6">
                        <label for="searchTerm" class="form-label">Search (Booking #, Event, Venue, Customer)</label>
                        <input type="text" class="form-control" id="searchTerm" name="searchTerm" 
                               value="@ViewBag.SearchTerm" placeholder="Enter search term...">
                    </div>

                    <!-- Customer Name -->
                    <div class="col-md-6">
                        <label for="customerName" class="form-label">Customer Name</label>
                        <input type="text" class="form-control" id="customerName" name="customerName" 
                               value="@ViewBag.CustomerName" placeholder="Enter customer name...">
                    </div>

                    <!-- Customer Phone -->
                    <div class="col-md-4">
                        <label for="customerPhone" class="form-label">Customer Phone</label>
                        <input type="text" class="form-control" id="customerPhone" name="customerPhone" 
                               value="@ViewBag.CustomerPhone" placeholder="Enter phone number...">
                    </div>

                    <!-- Status Filter -->
                    <div class="col-md-4">
                        <label for="statusFilter" class="form-label">Status</label>
                        <select class="form-select" id="statusFilter" name="statusFilter">
                            @foreach (var option in ViewBag.StatusOptions)
                            {
                                <option value="@option.Value" selected="@(option.Value == ViewBag.StatusFilter)">
                                    @option.Text
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Date Range -->
                    <div class="col-md-4">
                        <label for="dateRange" class="form-label">Date Range</label>
                        <select class="form-select" id="dateRange" name="dateRange" onchange="toggleCustomDateRange()">
                            <option value="">All Dates</option>
                            <option value="upcoming" selected="@(ViewBag.DateRange == "upcoming")">Upcoming</option>
                            <option value="past" selected="@(ViewBag.DateRange == "past")">Past</option>
                            <option value="today" selected="@(ViewBag.DateRange == "today")">Today</option>
                            <option value="custom" selected="@(ViewBag.DateRange == "custom")">Custom Range</option>
                        </select>
                    </div>

                    <!-- Custom Date Range -->
                    <div class="col-md-6" id="customDateRange" style="display: @(ViewBag.DateRange == "custom" ? "block" : "none")">
                        <label for="startDate" class="form-label">Start Date</label>
                        <input type="date" class="form-control" id="startDate" name="startDate" 
                               value="@ViewBag.StartDate">
                    </div>

                    <div class="col-md-6" id="customDateRangeEnd" style="display: @(ViewBag.DateRange == "custom" ? "block" : "none")">
                        <label for="endDate" class="form-label">End Date</label>
                        <input type="date" class="form-control" id="endDate" name="endDate" 
                               value="@ViewBag.EndDate">
                    </div>

                    <!-- Search Buttons -->
                    <div class="col-12">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-search"></i> Search
                        </button>
                        <a asp-action="EnhancedView" class="btn btn-secondary">
                            <i class="bi bi-arrow-clockwise"></i> Clear Filters
                        </a>
                        <button type="button" class="btn btn-info" onclick="exportToCSV()">
                            <i class="bi bi-download"></i> Export to CSV
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Results Summary -->
    <div class="row mb-3">
        <div class="col-md-6">
            <p class="text-muted">
                Showing <strong>@Model.Item1.Count</strong> of <strong>@Model.Item2.TotalItems</strong> bookings
            </p>
        </div>
        <div class="col-md-6 text-end">
            <div class="btn-group" role="group">
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="changePageSize(5)">5</button>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="changePageSize(10)">10</button>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="changePageSize(25)">25</button>
                <button type="button" class="btn btn-sm btn-outline-primary" onclick="changePageSize(50)">50</button>
            </div>
        </div>
    </div>

    <!-- Bookings Table -->
    <div class="card shadow">
        <div class="card-header bg-white">
            <h5 class="mb-0"><i class="bi bi-list-ul"></i> Booking Results</h5>
        </div>
        <div class="card-body">
            @if (Model.Item1.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover" id="bookingsTable">
                        <thead class="table-light">
                            <tr>
                                <th>Booking #</th>
                                <th>Customer</th>
                                <th>Event</th>
                                <th>Venue</th>
                                <th>Dates</th>
                                <th>Duration</th>
                                <th>Status</th>
                                <th>Attendees</th>
                                <th>Utilization</th>
                                <th>Created By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var booking in Model.Item1)
                            {
                                <tr>
                                    <td><strong>@booking.BookingNumber</strong></td>
                                    <td>
                                        <div>@booking.CustomerName @booking.CustomerSurname</div>
                                        <small class="text-muted">@booking.CustomerPhone</small>
                                        @if (!string.IsNullOrEmpty(booking.CustomerEmail))
                                        {
                                            <br /><small class="text-muted">@booking.CustomerEmail</small>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(booking.EventName))
                                        {
                                            <div><strong>@booking.EventName</strong></div>
                                            <small class="text-muted">
                                                @(booking.EventDate?.ToString("dd MMM yyyy") ?? "No date set")
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Event</span>
                                        }
                                    </td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(booking.VenueName))
                                        {
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(booking.VenueImageUrl))
                                                {
                                                    <img src="@booking.VenueImageUrl" alt="@booking.VenueName" 
                                                         class="me-2" style="width: 40px; height: 30px; object-fit: cover; border-radius: 4px;"
                                                         onerror="this.src='https://via.placeholder.com/40x30?text=V'">
                                                }
                                                <div>
                                                    <strong>@booking.VenueName</strong><br>
                                                    <small class="text-muted">@booking.VenueLocation</small>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <span class="text-muted">No Venue</span>
                                        }
                                    </td>
                                    <td>
                                        <div>@booking.StartDate.ToString("dd MMM yyyy")</div>
                                        <small class="text-muted">@booking.StartDate.ToString("HH:mm") - @booking.EndDate.ToString("HH:mm")</small>
                                    </td>
                                    <td><small>@booking.Duration</small></td>
                                    <td>
                                        <span class="badge @booking.StatusBadgeClass">
                                            @booking.Status
                                        </span>
                                    </td>
                                    <td>
                                        @if (booking.ExpectedAttendees.HasValue)
                                        {
                                            <span>@booking.ExpectedAttendees</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                    <td>
                                        <small>@booking.VenueUtilization</small>
                                    </td>
                                    <td>
                                        <small>@booking.CreatedByAdminName</small>
                                    </td>
                                    <td>
                                        <div class="btn-group" role="group">
                                            <a asp-action="Details" asp-route-id="@booking.BookingId" 
                                               class="btn btn-sm btn-outline-info" title="View Details">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                            <a asp-action="Edit" asp-route-id="@booking.BookingId" 
                                               class="btn btn-sm btn-outline-primary" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@booking.BookingId" 
                                               class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Pagination -->
                @if (Model.Item2.TotalPages > 1)
                {
                    <nav aria-label="Booking pagination">
                        <ul class="pagination justify-content-center">
                            @if (Model.Item2.HasPreviousPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="EnhancedView" 
                                       asp-route-searchTerm="@ViewBag.SearchTerm"
                                       asp-route-customerName="@ViewBag.CustomerName"
                                       asp-route-customerPhone="@ViewBag.CustomerPhone"
                                       asp-route-statusFilter="@ViewBag.StatusFilter"
                                       asp-route-dateRange="@ViewBag.DateRange"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       asp-route-pageNumber="@(Model.Item2.CurrentPage - 1)">Previous</a>
                                </li>
                            }

                            @for (int i = Model.Item2.StartPage; i <= Model.Item2.EndPage; i++)
                            {
                                <li class="page-item @(i == Model.Item2.CurrentPage ? "active" : "")">
                                    <a class="page-link" asp-action="EnhancedView"
                                       asp-route-searchTerm="@ViewBag.SearchTerm"
                                       asp-route-customerName="@ViewBag.CustomerName"
                                       asp-route-customerPhone="@ViewBag.CustomerPhone"
                                       asp-route-statusFilter="@ViewBag.StatusFilter"
                                       asp-route-dateRange="@ViewBag.DateRange"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       asp-route-pageNumber="@i">@i</a>
                                </li>
                            }

                            @if (Model.Item2.HasNextPage)
                            {
                                <li class="page-item">
                                    <a class="page-link" asp-action="EnhancedView"
                                       asp-route-searchTerm="@ViewBag.SearchTerm"
                                       asp-route-customerName="@ViewBag.CustomerName"
                                       asp-route-customerPhone="@ViewBag.CustomerPhone"
                                       asp-route-statusFilter="@ViewBag.StatusFilter"
                                       asp-route-dateRange="@ViewBag.DateRange"
                                       asp-route-startDate="@ViewBag.StartDate"
                                       asp-route-endDate="@ViewBag.EndDate"
                                       asp-route-pageNumber="@(Model.Item2.CurrentPage + 1)">Next</a>
                                </li>
                            }
                        </ul>
                    </nav>
                }
            }
            else
            {
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-muted"></i>
                    <h5 class="mt-3">No bookings found</h5>
                    <p class="text-muted">Try adjusting your search criteria or filters.</p>
                    <a asp-action="EnhancedView" class="btn btn-primary">
                        <i class="bi bi-arrow-clockwise"></i> Clear All Filters
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCustomDateRange() {
            const dateRange = document.getElementById('dateRange').value;
            const customRange = document.getElementById('customDateRange');
            const customRangeEnd = document.getElementById('customDateRangeEnd');
            
            if (dateRange === 'custom') {
                customRange.style.display = 'block';
                customRangeEnd.style.display = 'block';
            } else {
                customRange.style.display = 'none';
                customRangeEnd.style.display = 'none';
            }
        }

        function changePageSize(size) {
            const form = document.getElementById('searchForm');
            const currentUrl = new URL(window.location);
            currentUrl.searchParams.set('pageSize', size);
            currentUrl.searchParams.set('pageNumber', '1');
            window.location.href = currentUrl.toString();
        }

        function exportToCSV() {
            const table = document.getElementById('bookingsTable');
            if (!table) return;
            
            let csv = [];
            const headers = [];
            const headerCells = table.querySelectorAll('thead th');
            
            headerCells.forEach((cell, index) => {
                if (index < 10) { // Skip Actions column
                    headers.push(cell.textContent.trim());
                }
            });
            csv.push(headers.join(','));
            
            const rows = table.querySelectorAll('tbody tr');
            rows.forEach(row => {
                const rowData = [];
                const cells = row.querySelectorAll('td');
                
                cells.forEach((cell, index) => {
                    if (index < 10) { // Skip Actions column
                        let text = cell.textContent.trim();
                        // Remove extra whitespace and newlines
                        text = text.replace(/\s+/g, ' ');
                        // Escape quotes and wrap in quotes if contains comma
                        if (text.includes(',') || text.includes('"')) {
                            text = '"' + text.replace(/"/g, '""') + '"';
                        }
                        rowData.push(text);
                    }
                });
                csv.push(rowData.join(','));
            });
            
            const csvContent = csv.join('\n');
            const blob = new Blob([csvContent], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `bookings_export_${new Date().toISOString().split('T')[0]}.csv`;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }
    </script>
}
